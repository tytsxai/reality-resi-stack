port: 7890
socks-port: 7891
allow-lan: false
mode: rule
log-level: info
unified-delay: true

proxies:
  - name: @@NODE_NAME@@
    type: vless
    server: @@SERVER_IP@@
    port: @@INBOUND_PORT@@
    uuid: @@UUID@@
    network: tcp
    udp: true
    tls: true
    flow: xtls-rprx-vision
    servername: @@SNI@@
    client-fingerprint: chrome
    reality-opts:
      public-key: @@REALITY_PUBLIC_KEY@@
      short-id: "@@SHORT_ID@@"

proxy-groups:
  - name: PROXY
    type: url-test
    proxies:
      - @@NODE_NAME@@
    url: https://api.openai.com/v1/models
    expected-status: 401
    interval: 300
    lazy: false

  - name: GLOBAL
    type: select
    proxies:
      - PROXY

rules:
  - GEOSITE,CN,DIRECT
  - GEOIP,CN,DIRECT,no-resolve
  - MATCH,PROXY
