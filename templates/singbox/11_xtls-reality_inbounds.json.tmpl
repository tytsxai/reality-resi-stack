{
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-reality-@@INBOUND_PORT@@",
      "listen": "::",
      "listen_port": @@INBOUND_PORT@@,
      "users": [
        {
          "uuid": "@@UUID@@",
          "flow": "xtls-rprx-vision"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "@@SNI@@",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "@@SNI@@",
            "server_port": 443
          },
          "private_key": "@@REALITY_PRIVATE_KEY@@",
          "short_id": ["@@SHORT_ID@@"]
        }
      },
      "multiplex": {
        "enabled": false,
        "padding": false,
        "brutal": {
          "enabled": false,
          "up_mbps": 1000,
          "down_mbps": 1000
        }
      }
    }
  ]
}
