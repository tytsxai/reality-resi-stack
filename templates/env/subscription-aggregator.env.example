# Reality residential subscription aggregator — environment.
# This service runs on the data-center backup node. It polls the residential
# leaf's /status endpoint, caches the result, and serves a unified Clash
# profile listing BOTH nodes.

HOST=0.0.0.0
PORT=80

# Path-prefix token (independent from the leaf's TOKEN).
TOKEN=REPLACE_SUB_TOKEN

# Where to fetch the leaf's status JSON. Aggregator polls this URL.
REMOTE_STATUS_URL=http://@@RESI_SERVER_IP@@/REPLACE_REMOTE_TOKEN/status

# Timeout for one poll to the leaf status endpoint.
REMOTE_TIMEOUT_SECONDS=3

# Bytes to fall back to if the leaf is unreachable (avoids "0 used" cards).
FALLBACK_USED_BYTES=0

# Plan quota (typically the residential plan's quota — what the user cares about).
TOTAL_BYTES=0

# Plan expiry, Unix timestamp. 0 = never.
EXPIRE_TS=0

PROFILE_TITLE=Reality-Residential-Dual
UPDATE_INTERVAL_HOURS=24

# Per-client socket timeout. Keeps slow or abandoned HTTP clients from pinning
# subscription worker threads forever.
REQUEST_TIMEOUT_SECONDS=10

# Cache file (so leaf outages don't reset the displayed counter).
CACHE_FILE=/var/lib/reality-resi-stack/usage-cache.json

# How long to consider the cache fresh before re-polling the leaf.
CACHE_TTL_SECONDS=60

# Background polling interval. Keeps the cache warm even when no client is pulling.
REMOTE_POLL_INTERVAL_SECONDS=60

FILE_DIR=/etc/reality-resi-stack/files
DEFAULT_TARGET=profile.yaml
