# Reality residential subscription leaf — environment.
# Copy to /etc/reality-resi-stack/subscription-leaf.env on the server, then
# chmod 600 and chown root.

# Where to bind the subscription HTTP server.
HOST=0.0.0.0
PORT=80

# Path-prefix token. Clients fetch http://<server>/<TOKEN>/<file>.
# Generate fresh: uuidgen
TOKEN=REPLACE_SUB_TOKEN

# Network interface to read /sys/class/net/<iface>/statistics for traffic accounting.
# Find yours with: ip route get 1.1.1.1
INTERFACE=eth0

# Persistent state file (monthly rollover counter).
STATE_FILE=/var/lib/reality-resi-stack/usage-state.json

# Bytes already spent before this counter started (calibration). 0 if fresh.
USAGE_OFFSET_BYTES=0

# Plan quota in bytes (e.g. 1063004405760 = 990 GiB). 0 hides the bar.
TOTAL_BYTES=0

# Plan expiry as Unix timestamp. 0 = never.
EXPIRE_TS=0

# Display name shown in clients that honor Profile-Title header.
PROFILE_TITLE=Reality-Residential

# Suggested update interval (hours) for clients that honor Profile-Update-Interval.
UPDATE_INTERVAL_HOURS=24

# Directory of profile files (clash YAML, sing-box JSON, etc.) to serve.
FILE_DIR=/etc/reality-resi-stack/files

# Default file when client requests just /<TOKEN>/ with no filename.
DEFAULT_TARGET=profile.yaml
